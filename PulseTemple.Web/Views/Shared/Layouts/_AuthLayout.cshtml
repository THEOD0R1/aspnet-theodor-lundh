@{
    var pageTitle = !string.IsNullOrWhiteSpace(ViewData["Title"]?.ToString())
            ? $"{ViewData["Title"]} | PulseTemple" : "PulseTemple | Gym and Fitness";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PulseTemple.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-layout">
        <header class="header">
            <partial name="Partials/Headers/_HeaderSection" />

            @if (IsSectionDefined("HeaderHero"))
                @RenderSection("HeaderHero", required: false)
        </header>
            
        <main>
            @RenderBody()
        </main>
    </div>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
